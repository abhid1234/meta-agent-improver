[38.66357, "o", "\r\n"]
[38.968042, "o", "\r\n                     A40         L40S        H100\r\n  ─────────────────────────────────────────────────────\r\n  Depth 6, baseline  1.0980      1.0702      1.0795\r\n  Depth 6, optimized 1.0949 ⭐   1.0673 ⭐   1.0779\r\n  Depth 8, optimized  1.1017       —         1.0318 ⭐⭐\r\n  ─────────────────────────────────────────────────────\r\n"]
[41.972593, "o", "\u001b[2m# On budget GPUs, the meta-agent's prompt wins.\u001b[0m\r\n"]
[43.381598, "o", "\u001b[2m# On H100, depth=8 wins by 0.046 val_bpb — 15× the prompt gain.\u001b[0m\r\n"]
[45.9915, "o", "\u001b[2m# Does the optimized prompt transfer to other model families?\u001b[0m\r\n"]
